<div
  id="calculator-root"
  class="mx-auto max-w-5xl rounded-xl bg-canvas p-8 shadow-[0_2px_2px_#0000000a,0_8px_16px_-4px_#0000000a] ring-1 ring-inset ring-hairline md:p-10"
>
  <div class="mb-8">
    <span class="font-mono text-xs uppercase tracking-wide text-mute">Cost Estimator</span>
    <h2 class="mt-2 text-3xl font-semibold tracking-tight text-ink">
      Get Your Moving Estimate
    </h2>
    <p class="mt-1 text-body">
      Enter your origin, destination, and move details for instant three-way comparison.
    </p>
  </div>

  <form id="moveForm" class="space-y-5">
    <p class="text-xs text-mute">For a more accurate estimate, use ZIP or postal codes.</p>
    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="origin" class="mb-1.5 block text-sm font-medium text-ink">Origin</label>
        <input
          type="text"
          id="origin"
          name="origin"
          autocomplete="postal-code"
          required
          placeholder="City or ZIP / Postal Code"
          class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink outline-none ring-0 transition-shadow focus:border-ink"
        />
      </div>
      <div>
        <label for="destination" class="mb-1.5 block text-sm font-medium text-ink">Destination</label>
        <input
          type="text"
          id="destination"
          name="destination"
          autocomplete="postal-code"
          required
          placeholder="City or ZIP / Postal Code"
          class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink outline-none ring-0 transition-shadow focus:border-ink"
        />
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-4">
      <div class="sm:col-span-1">
        <label for="homeSize" class="mb-1.5 block text-sm font-medium text-ink">Home Size</label>
        <select
          id="homeSize"
          name="homeSize"
          class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink outline-none ring-0 transition-shadow focus:border-ink"
        >
          <option value="studio">Studio / 0 BR</option>
          <option value="1br" selected>1 Bedroom</option>
          <option value="2br">2 Bedrooms</option>
          <option value="3br">3 Bedrooms</option>
          <option value="4br">4 Bedrooms</option>
          <option value="5br">5+ Bedrooms</option>
        </select>
      </div>
      <div>
        <label for="moveDate" class="mb-1.5 block text-sm font-medium text-ink">Move Date</label>
        <input
          type="date"
          id="moveDate"
          name="moveDate"
          class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink outline-none ring-0 transition-shadow focus:border-ink"
        />
      </div>
      <div>
        <label for="region" class="mb-1.5 block text-sm font-medium text-ink">Region</label>
        <select
          id="region"
          name="region"
          class="h-10 w-full rounded-md border border-hairline bg-canvas px-3 text-sm text-ink outline-none ring-0 transition-shadow focus:border-ink"
        >
          <option value="US">United States ($)</option>
          <option value="CA">Canada (C$)</option>
          <option value="GB">United Kingdom (£)</option>
          <option value="AU">Australia (A$)</option>
          <option value="IN">India (₹)</option>
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink">Unit</label>
        <div class="flex h-10 overflow-hidden rounded-md border border-hairline bg-canvas p-0.5">
          <button type="button" id="unitMi" class="unit-btn flex-1 rounded px-2 text-sm font-medium transition-all bg-ink text-on-ink" data-unit="mi">Miles</button>
          <button type="button" id="unitKm" class="unit-btn flex-1 rounded px-2 text-sm font-medium transition-all bg-canvas text-body hover:text-ink" data-unit="km">KM</button>
        </div>
      </div>
    </div>
  </form>

  <div id="loading" class="mt-6 hidden text-center text-sm text-mute">
    <span class="inline-block animate-pulse">Calculating distance...</span>
  </div>

  <div id="distanceSection" class="mt-6 hidden">
    <label class="mb-1.5 flex items-baseline justify-between text-sm font-medium text-ink">
      <span>Distance</span>
      <span id="distanceLabel" class="font-mono text-xs text-mute">0 mi</span>
    </label>
    <input
      type="range"
      id="distanceSlider"
      min="15"
      max="2800"
      step="1"
      value="100"
      class="w-full"
    />
    <div class="mt-1 flex justify-between text-xs text-mute">
      <span id="distMinLabel">15 mi</span>
      <span id="distMaxLabel">2,800 mi</span>
    </div>
  </div>

  <button
    id="calculateBtn"
    class="mt-6 inline-flex cursor-pointer items-center gap-2 rounded-full bg-ink px-7 py-3 text-base font-medium text-on-ink transition-opacity hover:opacity-90"
  >
    Get Estimate
  </button>

  <div id="results" class="mt-10 hidden space-y-8">
    <div class="grid gap-6 md:grid-cols-3">
      <div class="estimate-card rounded-lg border border-hairline bg-canvas p-6" data-tier="diy">
        <span class="font-mono text-xs uppercase tracking-wide text-mute">Option 1</span>
        <h3 class="mt-1 text-lg font-semibold text-ink">DIY Truck Rental</h3>
        <p class="mt-1 text-xs text-body">Rent a truck, drive it yourself</p>
        <div class="mt-4">
          <span class="estimate-amount text-3xl font-semibold tracking-tight text-ink">$0</span>
        </div>
        <ul class="mt-4 space-y-1.5 text-xs text-body">
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Truck rental included
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Fuel cost included
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            You load &amp; drive
          </li>
        </ul>
        <div class="mt-4 border-t border-hairline pt-3 text-xs text-mute">
          <span class="estimate-detail">Base: $0 • Per <span class="per-unit">mi</span>: $0.00</span>
        </div>
      </div>

      <div class="estimate-card rounded-lg border-2 border-ink bg-canvas p-6 shadow-[0_2px_2px_#0000000a,0_8px_16px_-4px_#0000000a]" data-tier="container">
        <span class="inline-block rounded-full bg-ink px-2 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wide text-on-ink">Popular</span>
        <span class="mt-1 block font-mono text-xs uppercase tracking-wide text-mute">Option 2</span>
        <h3 class="mt-1 text-lg font-semibold text-ink">Moving Containers</h3>
        <p class="mt-1 text-xs text-body">Portable container delivered to you</p>
        <div class="mt-4">
          <span class="estimate-amount text-3xl font-semibold tracking-tight text-ink">$0</span>
        </div>
        <ul class="mt-4 space-y-1.5 text-xs text-body">
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Container delivery &amp; pickup
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            You pack at your pace
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            30-day storage included
          </li>
        </ul>
        <div class="mt-4 border-t border-hairline pt-3 text-xs text-mute">
          <span class="estimate-detail">Base: $0 • Per <span class="per-unit">mi</span>: $0.00</span>
        </div>
      </div>

      <div class="estimate-card rounded-lg border border-hairline bg-canvas p-6" data-tier="pro">
        <span class="font-mono text-xs uppercase tracking-wide text-mute">Option 3</span>
        <h3 class="mt-1 text-lg font-semibold text-ink">Professional Movers</h3>
        <p class="mt-1 text-xs text-body">Full-service moving crew</p>
        <div class="mt-4">
          <span class="estimate-amount text-3xl font-semibold tracking-tight text-ink">$0</span>
        </div>
        <ul class="mt-4 space-y-1.5 text-xs text-body">
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Professional crew included
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Loading &amp; unloading
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Full insurance coverage
          </li>
        </ul>
        <div class="mt-4 border-t border-hairline pt-3 text-xs text-mute">
          <span class="estimate-detail">Base: $0 • Per <span class="per-unit">mi</span>: $0.00</span>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-mute">
      Estimates in <span id="currencyLabel">United States ($)</span>. <span id="regionPricingLabel"></span>
      Prices vary by location and season. Contact providers for a firm quote.
    </p>

    <!-- Social Sharing Bar -->
    <div id="shareSection" class="flex flex-col items-center justify-between gap-4 border-t border-b border-hairline py-6 sm:flex-row">
      <div class="text-center sm:text-left">
        <h4 class="text-sm font-semibold text-ink">Share this estimate</h4>
        <p class="text-xs text-mute">Send your route and comparison to family or friends.</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2">
        <!-- Twitter/X -->
        <a
          id="shareTwitter"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Share on X (Twitter)"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span class="sr-only">Share on X (Twitter)</span>
        </a>

        <!-- Facebook -->
        <a
          id="shareFacebook"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Share on Facebook"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
          </svg>
          <span class="sr-only">Share on Facebook</span>
        </a>

        <!-- WhatsApp -->
        <a
          id="shareWhatsApp"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Share on WhatsApp"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="sr-only">Share on WhatsApp</span>
        </a>

        <!-- Email -->
        <a
          id="shareEmail"
          href="#"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Share via Email"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="sr-only">Share via Email</span>
        </a>

        <!-- PDF/Print Export -->
        <button
          id="sharePrint"
          type="button"
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Export to PDF"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </button>

        <!-- Copy Link -->
        <button
          id="shareCopy"
          type="button"
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-hairline bg-canvas text-body transition-colors hover:bg-canvas-soft hover:text-ink"
          aria-label="Copy sharing link"
        >
          <svg id="copyIcon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
          <svg id="checkIcon" class="hidden h-4 w-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </button>
      </div>
    </div>

    <div id="moversSection" class="hidden rounded-lg border border-hairline bg-canvas p-6">
      <span class="font-mono text-xs uppercase tracking-wide text-mute">Recommended For You</span>
      <h3 class="mt-1 text-lg font-semibold text-ink">Top Professional Movers in <span id="regionName">Your Area</span></h3>
      <p class="mt-1 text-xs text-body">These providers serve your region. Click to get a free quote.</p>
      <div id="moversList" class="mt-4 grid gap-3 sm:grid-cols-2"></div>
    </div>
  </div>
</div>

<script>
  let loaded = false;
  function loadLogic() {
    if (loaded) return;
    loaded = true;
    
    // Remove listeners
    window.removeEventListener('load', loadLogic);
    const formInputs = document.querySelectorAll('#moveForm input, #moveForm select, #moveForm button');
    formInputs.forEach(el => {
      el.removeEventListener('focus', loadLogic);
      el.removeEventListener('click', loadLogic);
    });

    import('./MovingCostCalculatorLogic');
  }

  // Load on window load
  window.addEventListener('load', loadLogic);

  // Or load when user interacts with the form elements
  const formInputs = document.querySelectorAll('#moveForm input, #moveForm select, #moveForm button');
  formInputs.forEach(el => {
    el.addEventListener('focus', loadLogic, { once: true, passive: true });
    el.addEventListener('click', loadLogic, { once: true, passive: true });
  });
</script>
