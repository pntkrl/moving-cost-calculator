---
export interface Props {
  currentPath?: string;
}

const { currentPath } = Astro.props;
---

<footer class="border-t border-hairline bg-canvas px-4 py-12 sm:px-6">
  <div class="mx-auto flex max-w-5xl flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2 text-sm text-mute">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none" class="text-ink" aria-hidden="true">
          <rect width="32" height="32" rx="6" fill="currentColor" />
          <path d="M10 20V12h3l3 4 3-4h3v8h-3v-4l-3 4-3-4v4H10Z" fill="currentColor" class="text-on-ink" />
        </svg>
        <span class="font-semibold text-ink">MoveCostMatrix</span>
        <span>&middot; movecostmatrix.com</span>
      </div>
      <p class="max-w-xs text-xs text-mute">&copy; 2026 MoveCostMatrix. Estimates for planning &mdash; not guaranteed quotes.</p>
    </div>
    <nav class="flex flex-wrap gap-x-8 gap-y-2 text-sm" aria-label="Footer navigation">
      <a href="/about" aria-current={currentPath === "/about" ? "page" : undefined} class="text-mute no-underline transition-colors hover:text-ink">About</a>
      <a href="/contact" aria-current={currentPath === "/contact" ? "page" : undefined} class="text-mute no-underline transition-colors hover:text-ink">Contact</a>
      <a href="/privacy" aria-current={currentPath === "/privacy" ? "page" : undefined} class="text-mute no-underline transition-colors hover:text-ink">Privacy Policy</a>
      <a href="/terms" aria-current={currentPath === "/terms" ? "page" : undefined} class="text-mute no-underline transition-colors hover:text-ink">Terms &amp; Conditions</a>
      <a href="/press" aria-current={currentPath === "/press" ? "page" : undefined} class="text-mute no-underline transition-colors hover:text-ink">Press</a>
      <a href="/sitemap.xml" class="text-mute no-underline transition-colors hover:text-ink">Sitemap</a>
    </nav>
  </div>
</footer>
