---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Press | MoveCostMatrix" description="MoveCostMatrix press and media resources. Free moving cost calculator press kit, brand assets, and media contact information." canonical="/press">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://movecostmatrix.com/" },
        { "@type": "ListItem", "position": 2, "name": "Press", "item": "https://movecostmatrix.com/press" }
      ]
    }
  </script>
  <Nav currentPath="/press" />

  <main>
  <section class="bg-canvas px-4 pb-28 pt-16 sm:pb-36 sm:pt-24">
    <div class="mx-auto max-w-3xl">
      <span class="font-mono text-xs uppercase tracking-wide text-mute">Press</span>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-ink">Press & Media</h1>
      <p class="mt-2 max-w-xl text-body">Resources for journalists and media professionals covering MoveCostMatrix.</p>

      <div class="mt-10 space-y-6">
        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">About MoveCostMatrix</h2>
          <p class="mt-1 text-sm text-body">MoveCostMatrix is a free, privacy-first moving cost calculator that compares DIY truck rentals, portable moving containers, and full-service professional movers side by side. No email required, no data collection, no upsells — just instant estimates in 7 currencies.</p>
        </div>

        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">Key Facts</h2>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-body">
            <li>Launched: July 2026</li>
            <li>Platform: Fully static, 100% client-side</li>
            <li>Distance engine: Haversine formula + 20% road adjustment via zippopotam.us API</li>
            <li>Coverage: US, Canada, UK, Australia, India postal codes with region-adjusted pricing</li>
            <li>Privacy: No accounts or registration, zero collection of calculator inputs, with basic anonymized traffic analytics</li>
          </ul>
        </div>

        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">Media Contact</h2>
          <p class="mt-1 text-sm text-body">For press inquiries, interviews, or brand assets, contact us at <a href="mailto:hello@movecostmatrix.com" class="text-link underline">hello@movecostmatrix.com</a>.</p>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer currentPath="/press" />
</Layout>
