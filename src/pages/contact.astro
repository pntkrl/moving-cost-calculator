---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact MoveCostMatrix | Get in Touch" description="Get in touch with MoveCostMatrix. Report issues, suggest features, or ask questions about our free moving cost calculator." canonical="/contact">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://movecostmatrix.com/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://movecostmatrix.com/contact" }
      ]
    }
  </script>
  <Nav currentPath="/contact" />

  <main>
  <section class="bg-canvas px-4 pb-28 pt-16 sm:pb-36 sm:pt-24">
    <div class="mx-auto max-w-3xl">
      <span class="font-mono text-xs uppercase tracking-wide text-mute">Contact</span>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-ink">Get in Touch</h1>
      <p class="mt-2 max-w-xl text-body">Have a question, suggestion, or found a bug? We would love to hear from you. Your feedback helps us make MoveCostMatrix better for everyone.</p>

      <div class="mt-10 space-y-6">
        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">Email Us</h2>
          <p class="mt-1 text-sm text-body">Send us an email at <!--email_off--><a href="mailto:hello@movecostmatrix.com" class="text-link underline">hello@movecostmatrix.com</a><!--/email_off-->. We aim to respond within 48 hours. Whether you have a question about your moving estimate, encountered a bug in the calculator, or just want to share feedback, we are here to help.</p>
        </div>

        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">Report Issues on GitHub</h2>
          <p class="mt-1 text-sm text-body">Found a bug or want to suggest a feature? Open an issue on our <a href="https://github.com/pntkrl/moving-cost-calculator" target="_blank" rel="noopener noreferrer" class="text-link underline">GitHub repository</a>. You can report calculation inaccuracies, request support for new regions or currencies, or submit feature ideas like additional moving methods or export options. We review all issues regularly and respond to most within a week.</p>
        </div>

        <div class="rounded-lg border border-hairline bg-canvas-soft p-6">
          <h2 class="text-lg font-semibold text-ink">Before You Contact Us</h2>
          <p class="mt-1 text-sm text-body">Check our <a href="/privacy" class="text-link underline">Privacy Policy</a> to understand how we handle your data, or review the <a href="/terms" class="text-link underline">Terms and Conditions</a> for details on using the service. Many common questions are answered there, including how our calculator works, what data we collect, and our legal disclaimers.</p>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer currentPath="/contact" />
</Layout>
